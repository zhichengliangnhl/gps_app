<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/welcomeText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hello, NavigationApp!"
        android:textSize="18sp"
        android:textAlignment="center"
        android:textColor="#000000"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/waypointName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Waypoint Name" />

    <EditText
        android:id="@+id/waypointDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Waypoint Description" />

    <Button
        android:id="@+id/addWaypointBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add Waypoint"
        android:layout_marginTop="8dp"
        android:layout_gravity="center_horizontal" />

    <ListView
        android:id="@+id/waypointListView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp" />
</LinearLayout>
